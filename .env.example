# Shared non-secrets only. Each stack's .env symlinks to this file.
# --------------------------------------------------------------
# Real secrets (BESZEL_AGENT_KEY, PIA_USERNAME, PIA_PASSWORD, GitHub PAT)
# live in 1Password and are referenced from per-stack secrets.env files.
# See README "Where every env var lives" for the full breakdown.

TZ='America/Los_Angeles'
PUID=1000
PGID=1000

# DNS servers for qbittorrent-wireguard (public, non-secret)
NAME_SERVERS='1.1.1.1,8.8.8.8'

# --- historical / optional (uncomment if re-enabling SWAG + DuckDNS) ---
# DUCKDNS_URL='URL.duckdns.org'
# DUCKDNS_TOKEN='TOKEN'
# URL='URL'
