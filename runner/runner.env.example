# Runner local config — gitignored copy to runner.env and chmod 600 it.
#
# The GitHub PAT (ACCESS_TOKEN) now lives in 1Password and is resolved
# via secrets.env; don't put it here. The only sensitive value in this
# file is OP_SERVICE_ACCOUNT_TOKEN, which bootstraps `op run` and
# therefore can't be stored in 1Password itself.

# GitHub runner configuration (non-secret identity, consumed by
# myoung34/github-runner at registration time)
# --------------------------------------------------------------
REPO_URL=https://github.com/YOUR_USER/YOUR_REPO
RUNNER_NAME=home-server
RUNNER_SCOPE=repo
LABELS=self-hosted,linux,home
EPHEMERAL=false

# 1Password service account token (bootstrap — consumed by `op run`
# inside workflows and by containerupdater.sh to resolve op:// refs)
# --------------------------------------------------------------
OP_SERVICE_ACCOUNT_TOKEN=ops_PASTE_SERVICE_ACCOUNT_TOKEN_HERE
