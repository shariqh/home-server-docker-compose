# GitHub runner configuration (consumed by myoung34/github-runner)
# --------------------------------------------------------------
REPO_URL=https://github.com/YOUR_USER/YOUR_REPO
ACCESS_TOKEN=ghp_PAT_WITH_REPO_SCOPE_HERE
RUNNER_NAME=home-server
RUNNER_SCOPE=repo
LABELS=self-hosted,linux,home
EPHEMERAL=false

# 1Password service account token (consumed by `op run` inside workflows)
# --------------------------------------------------------------
# Scope the service account to only the vault(s) this runner needs to read.
OP_SERVICE_ACCOUNT_TOKEN=ops_PASTE_SERVICE_ACCOUNT_TOKEN_HERE
