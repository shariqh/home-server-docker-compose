# 1Password secret references for the runner stack.
# Safe to commit — these are pointers, not secret values. Resolved at
# `docker compose up` time by `op run`.
#
# Note: OP_SERVICE_ACCOUNT_TOKEN itself stays in runner.env as a plain
# value — it's the bootstrap credential that makes `op run` work in the
# first place, so it can't live behind an op:// reference.

ACCESS_TOKEN=op://home-server/ubi-prod-envs/github_runner_pat
