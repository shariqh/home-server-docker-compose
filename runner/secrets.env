# 1Password secret references for the runner stack.
# Safe to commit — these are pointers, not secret values. Resolved at
# `docker compose up` time by `op run`.
#
# Note: OP_SERVICE_ACCOUNT_TOKEN itself stays in runner.env as a plain
# value — it's the bootstrap credential that makes `op run` work in the
# first place, so it can't live behind an op:// reference.

ACCESS_TOKEN=op://dev-env-vars/ubi-prod-envs/Home Server/github_runner_pat

# Coreworx-LLC org runner (runner-coreworx service). Separate PAT with
# admin:org scope on Coreworx-LLC so myoung34/github-runner can mint org
# registration tokens. Create the field in the same 1Password item.
COREWORX_ACCESS_TOKEN=op://dev-env-vars/ubi-prod-envs/Home Server/coreworx_runner_pat
