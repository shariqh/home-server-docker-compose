# Coreworx-LLC ORG backup runner — gitignored copy to runner-coreworx.env and
# chmod 600 it. This backs every project-portals repo in the Coreworx-LLC org
# when GitHub-hosted Actions are blocked (Actions spending limit).
#
# The GitHub PAT (ACCESS_TOKEN) lives in 1Password and is resolved via
# secrets.env (COREWORX_ACCESS_TOKEN) — don't put it here. The only sensitive
# value in this file is OP_SERVICE_ACCOUNT_TOKEN (same one as runner.env).

# Org-scoped runner identity (consumed by myoung34/github-runner at
# registration time). ORG_NAME + RUNNER_SCOPE=org means ONE runner serves
# every repo in the org; workflows opt in by targeting the coreworx-backup
# label so this never grabs unrelated jobs.
# --------------------------------------------------------------
RUNNER_SCOPE=org
ORG_NAME=Coreworx-LLC
RUNNER_NAME=ubi-prod-coreworx-backup
LABELS=self-hosted,linux,x64,coreworx-backup
EPHEMERAL=false
# Optional: if you create a dedicated runner group in the org scoped to just
# the project-portals repos, set it here (otherwise the default group serves
# all org repos, which the coreworx-backup label already gates).
# RUNNER_GROUP=coreworx-backup

# 1Password service account token (bootstrap — same value as runner.env;
# lets `op run` resolve op:// refs). Required by the shared op-run flow.
# --------------------------------------------------------------
OP_SERVICE_ACCOUNT_TOKEN=ops_PASTE_SERVICE_ACCOUNT_TOKEN_HERE
