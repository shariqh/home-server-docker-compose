# draw.io source files
*.drawio

# appdata — persistent bind mounts, with a few tracked configs
appdata/*
!appdata/filebeat/filebeat.docker.yml
!appdata/logstash/pipeline/nginx.conf
!appdata/logstash/logstash.yml
!appdata/lidarr/

# allowlist tracked swag configs
!appdata/swag/
appdata/swag/*
!appdata/swag/nginx/
appdata/swag/nginx/*
!appdata/swag/nginx/site-confs/

# backups (operator-managed)
backup

# macOS cruft
.DS_Store

# beszel persistent data
beszel_data/

# env files with real values
*.env
# …but keep per-stack symlinks to the shared root .env
!*/.env
# …and per-stack secret-reference files (op:// pointers, no values)
!*/secrets.env

# runner local state volumes when mounted as bind mounts
runner/runner-data/
